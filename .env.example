# ============================================
# COPIV TIKAL S.A. — Variables de Entorno
# Copia este archivo como .env y completa
# ============================================

# --- Sanity CMS ---
PUBLIC_SANITY_PROJECT_ID=your-project-id
PUBLIC_SANITY_DATASET=production

# --- Gemini API (Chat) ---
PUBLIC_GEMINI_API_KEY=your-gemini-api-key

# --- API Backend URL (para formularios en local) ---
# En producción se usa ruta relativa (/api) automáticamente.
# Para pruebas locales con PHP Server, descomenta y apunta a tu servidor:
# PUBLIC_API_URL=http://localhost:8000/api

# --- FTP Deploy (GitHub Secrets, no .env) ---
# FTP_SERVER=ftp.tudominio.com
# FTP_USERNAME=usuario_cpanel
# FTP_PASSWORD=contraseña_segura
