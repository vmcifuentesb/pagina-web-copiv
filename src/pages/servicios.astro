---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlueprintExploder from '../components/ui/BlueprintExploder';
import ServicesGrid from '../components/ui/ServicesGrid';
import { resolvePath } from '../utils/constants';
---

<BaseLayout title="Nuestros Servicios - COPIV TIKAL" description="Soluciones integrales de seguridad privada, agentes uniformados, polígrafo y control de acceso." heroImg="/images/hero_servicios.png">
  
  <!-- Header Section -->
  <div class="bg-gradient-to-b from-white to-copiv-lightGray py-16 border-b border-copiv-green/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-4">
      <span class="text-copiv-red font-bold text-sm uppercase tracking-widest block">Catálogo de Servicios</span>
      <h1 class="text-4xl font-montserrat font-extrabold text-gray-900 m-0">Nuestras Soluciones de Seguridad de Elite</h1>
      <p class="text-gray-600 max-w-2xl mx-auto font-sans">Garantizamos la continuidad operativa de su empresa mediante protocolos rigurosos y tecnología adaptada a su infraestructura.</p>
    </div>
  </div>

  <!-- DESPIECE TÉCNICO INTERACTIVO (HARDWARE EXPLODER) -->
  <div class="py-16 bg-white border-b border-copiv-green/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-12 space-y-3">
        <span class="text-xs text-copiv-green font-bold uppercase tracking-widest block"><i class="fa-solid fa-microchip mr-1"></i> Despiece Técnico de Infraestructura</span>
        <h2 class="text-2xl sm:text-3xl font-montserrat font-bold text-gray-900 m-0">Sistemas Integrados de Seguridad COPIV</h2>
        <p class="text-xs text-gray-600 font-sans">Haga clic sobre los hotspots de la garita inteligente para revelar los detalles de ingeniería que protegen sus activos.</p>
      </div>

      <!-- React Island -->
      <BlueprintExploder client:load />
    </div>
  </div>

  <!-- Services Filter & Grid -->
  <div class="py-16 bg-copiv-lightGray">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <!-- React Island -->
      <ServicesGrid client:visible />
    </div>
  </div>

  <!-- Cross-Linking CTA -->
  <section class="bg-copiv-black py-16 text-center border-t border-copiv-green/20">
    <div class="max-w-4xl mx-auto px-4">
      <h2 class="text-2xl font-bold font-montserrat text-gray-900 mb-6">Integre Tecnología a su Seguridad Física</h2>
      <p class="text-gray-600 font-sans mb-8">Potencie la eficiencia de nuestros agentes uniformados con controles de acceso biométricos y CCTV inteligente.</p>
      <div class="flex flex-col sm:flex-row justify-center gap-4">
        <a href={resolvePath('productos')} class="inline-flex items-center justify-center gap-2 bg-copiv-gold text-copiv-black hover:bg-white font-bold px-8 py-3.5 rounded-xl transition-colors duration-300 decoration-none shadow-lg">
          Explorar Soluciones Tecnológicas <i class="fa-solid fa-microchip"></i>
        </a>
        <a href={resolvePath('empresa')} class="inline-flex items-center justify-center gap-2 bg-transparent border-2 border-copiv-green text-copiv-green hover:bg-copiv-green hover:text-white font-bold px-8 py-3.5 rounded-xl transition-all duration-300 decoration-none shadow-lg">
          Conocer La Empresa <i class="fa-solid fa-building-shield"></i>
        </a>
      </div>
    </div>
  </section>

</BaseLayout>
