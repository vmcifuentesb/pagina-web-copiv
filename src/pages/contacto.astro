---
import BaseLayout from '../layouts/BaseLayout.astro';
import ContactForm from '../components/ui/ContactForm';
---

<BaseLayout title="Contacto y Ubicaciones - COPIV TIKAL" description="Contáctenos 24/7/365. Solicite asesoría de seguridad táctica para su empresa, industria o condominio en Guatemala.">
  
  <div class="bg-gradient-to-b from-white to-copiv-lightGray py-16 border-b border-copiv-green/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-4">
      <span class="text-copiv-red font-bold text-sm uppercase tracking-widest block">Atención Inmediata</span>
      <h1 class="text-4xl font-montserrat font-extrabold text-gray-900 m-0">Contacto y Ubicaciones</h1>
      <p class="text-gray-600 max-w-2xl mx-auto font-sans">Estamos disponibles 24/7/365 en todo el territorio de la República de Guatemala. Contáctenos hoy mismo.</p>
    </div>
  </div>

  <div class="py-16 bg-copiv-black">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12">
        
        <!-- Left info -->
        <div class="lg:col-span-5 space-y-8">
          <div class="bg-white border border-gray-200 rounded-2xl p-6 space-y-6 text-left shadow-sm">
            <h3 class="font-montserrat font-bold text-xl text-gray-900 border-b border-gray-100 pb-3 m-0">Información Corporativa</h3>
            
            <div class="space-y-4">
              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-copiv-green/10 flex items-center justify-center text-copiv-green mt-1 shrink-0">
                  <i class="fa-solid fa-map-location-dot"></i>
                </div>
                <div>
                  <span class="text-[10px] text-gray-500 uppercase tracking-wider block font-sans">Dirección Central:</span>
                  <p class="text-sm text-gray-800 font-semibold font-sans m-0 leading-relaxed">15 avenida 1-73 Ciudad San Cristóbal Z.8 Mixco, Guatemala.</p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-copiv-green/10 flex items-center justify-center text-copiv-green mt-1 shrink-0">
                  <i class="fa-solid fa-phone-volume"></i>
                </div>
                <div>
                  <span class="text-[10px] text-gray-500 uppercase tracking-wider block font-sans">Teléfonos de Enlace Directo:</span>
                  <p class="text-sm text-gray-800 font-semibold flex flex-col font-mono m-0 leading-relaxed">
                    <a href="tel:+50230990692" class="text-copiv-green hover:text-copiv-goldDark decoration-none">+502 3099 0692 (Ventas / WhatsApp)</a>
                    <a href="tel:+50248542084" class="text-copiv-green hover:text-copiv-goldDark decoration-none">+502 4854 2084 (Soporte Técnico)</a>
                  </p>
                </div>
              </div>

              <div class="flex items-start gap-4">
                <div class="w-10 h-10 rounded-lg bg-copiv-green/10 flex items-center justify-center text-copiv-green mt-1 shrink-0">
                  <i class="fa-solid fa-envelope-open-text"></i>
                </div>
                <div>
                  <span class="text-[10px] text-gray-500 uppercase tracking-wider block font-sans">Correos Electrónicos:</span>
                  <p class="text-sm text-gray-800 font-semibold flex flex-col m-0 leading-relaxed">
                    <a href="mailto:ventas@copivgt.com" class="text-copiv-green hover:text-copiv-goldDark font-mono decoration-none">ventas@copivgt.com</a>
                    <a href="mailto:soportecnico@copivgt.com" class="text-copiv-green hover:text-copiv-goldDark font-mono decoration-none">soportecnico@copivgt.com</a>
                  </p>
                </div>
              </div>
            </div>
          </div>

          <!-- Interactive Map Container -->
          <div class="bg-white border border-gray-200 rounded-2xl p-4 overflow-hidden shadow-sm space-y-3 text-left">
            <span class="text-xs text-gray-900 font-bold block font-montserrat">Ubicación de Nuestras Oficinas</span>
            
            <div class="w-full h-[300px] rounded-xl overflow-hidden border border-copiv-green/30 relative">
              <iframe 
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15444.606362544155!2d-90.5843!3d14.5954!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8589a1afdf958019%3A0x7d6c63ed65c71a33!2sCiudad%20San%20Crist%C3%B3bal%2C%20Mixco%2C%20Guatemala!5e0!3m2!1ses!2sus!4v1718301234567!5m2!1ses!2sus" 
                class="absolute top-0 left-0 w-full h-full border-0" 
                allowfullscreen="" 
                loading="lazy" 
                referrerpolicy="no-referrer-when-downgrade">
              </iframe>
            </div>
          </div>
        </div>

        <!-- Right form -->
        <div class="lg:col-span-7 bg-white border border-gray-200 rounded-2xl p-6 sm:p-8 shadow-sm">
          <h3 class="font-montserrat font-bold text-2xl text-gray-900 mb-2 text-left m-0">Solicitar Asesoría Personalizada</h3>
          <p class="text-gray-600 text-xs mb-6 font-sans text-left leading-relaxed">¿Tiene alguna duda sobre agentes de seguridad o sistemas tácticos de CCTV? Escríbanos y recibirá atención comercial inmediata.</p>
          
          {/* React Island for Contact Form */}
          <ContactForm client:load />
        </div>
      </div>
    </div>
  </div>

</BaseLayout>
