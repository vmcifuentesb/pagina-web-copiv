---
import BaseLayout from '../layouts/BaseLayout.astro';
import { Image } from 'astro:assets';
import { resolvePath } from '../utils/constants';
---

<BaseLayout title="COPIV TIKAL - Seguridad Privada de Elite" description="Diseñamos ecosistemas de protección inteligentes que fusionan la fuerza táctica operativa con soluciones de monitoreo avanzadas en Guatemala." heroImg="/images/hero_home.png">
  
  <!-- Hero Section -->
  <div class="relative bg-gradient-to-b from-copiv-darkGray to-copiv-black pt-16 pb-24 md:py-32 overflow-hidden border-b border-copiv-green/20">
    <!-- Grid background layout -->
    <div class="absolute inset-0 opacity-10 bg-[radial-gradient(#37553a_1.5px,transparent_1.5px)] [background-size:24px_24px]"></div>
    
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-12 items-center">
        <!-- Left text with GSAP animation -->
        <div class="lg:col-span-7 space-y-6 text-center lg:text-left">
          <div class="gsap-hero-item inline-flex items-center gap-2 px-3 py-1 bg-copiv-green/10 border border-copiv-green/20 rounded-full text-xs font-semibold text-copiv-green uppercase tracking-wider">
            <span class="flex h-2 w-2 rounded-full bg-copiv-red animate-pulse"></span>
            Protección con Alta Tecnología de Seguridad
          </div>
          
          <h1 class="gsap-hero-item text-4xl sm:text-5xl md:text-6xl font-montserrat font-black tracking-tight leading-none text-gray-900">
            Tu tranquilidad es <br class="hidden sm:inline" />
            <span class="text-gradient font-black">nuestra ciencia</span>,<br />
            tu seguridad nuestra meta.
          </h1>
          
          <p class="gsap-hero-item text-gray-600 text-base sm:text-lg max-w-xl mx-auto lg:mx-0 font-light leading-relaxed font-sans">
            En <strong class="text-copiv-green font-bold">COPIV TIKAL</strong> diseñamos ecosistemas de protección inteligentes que fusionan la fuerza táctica operativa con soluciones de monitoreo avanzadas para blindar su patrimonio nacional.
          </p>
          
          <div class="gsap-hero-item flex flex-col sm:flex-row justify-center lg:justify-start gap-4 pt-4">
            <a href={resolvePath('diagnostico')} class="bg-gradient-to-r from-copiv-red to-copiv-redDark text-white font-bold px-8 py-4 rounded-xl shadow-lg shadow-copiv-red/30 hover:scale-105 hover:shadow-copiv-red/40 transition-all flex items-center justify-center gap-2 decoration-none cursor-pointer">
              <i class="fa-solid fa-list-check"></i> Iniciar Autodiagnóstico de Riesgo
            </a>
            <a href={resolvePath('servicios')} class="border border-copiv-green hover:border-copiv-gold text-copiv-green hover:text-copiv-goldDark font-semibold px-8 py-4 rounded-xl hover:bg-copiv-green/10 transition-all flex items-center justify-center gap-2 decoration-none cursor-pointer">
              Conocer Servicios <i class="fa-solid fa-shield"></i>
            </a>
          </div>

          <!-- KPIs de Reacción en Tiempo Real -->
          <div class="gsap-hero-item pt-8 border-t border-copiv-green/10 max-w-lg mx-auto lg:mx-0 text-left">
            <span class="text-xs text-copiv-green font-bold uppercase tracking-wider block mb-4"><i class="fa-solid fa-chart-line mr-1"></i> Indicadores de Respuesta Operativa (Guatemala)</span>
            <div class="grid grid-cols-3 gap-4">
              <div class="bg-white border border-gray-200 rounded-xl p-3 text-center shadow-sm">
                <span class="block text-2xl font-bold font-montserrat text-copiv-green">11.4m</span>
                <span class="block text-[10px] text-gray-600">Reacción Moto-Patrulla</span>
              </div>
              <div class="bg-white border border-gray-200 rounded-xl p-3 text-center shadow-sm">
                <span class="block text-2xl font-bold font-montserrat text-copiv-red">99.8%</span>
                <span class="block text-[10px] text-gray-600">Prevención CCTV + IA</span>
              </div>
              <div class="bg-white border border-gray-200 rounded-xl p-3 text-center shadow-sm">
                <span class="block text-2xl font-bold font-montserrat text-copiv-green">+2,400h</span>
                <span class="block text-[10px] text-gray-600">Capacitación Táctica</span>
              </div>
            </div>
          </div>
        </div>

        <!-- Right Graphic Photo Panel with Laser Scanner Effect -->
        <div class="lg:col-span-5 relative">
          <div class="relative mx-auto max-w-sm lg:max-w-none">
            <!-- Glowing Aura Background -->
            <div class="absolute inset-0 bg-gradient-to-tr from-copiv-green/20 to-copiv-gold/10 rounded-3xl blur-3xl -z-10 animate-pulse"></div>
            
            <div class="bg-white border border-gray-200 rounded-3xl p-2 shadow-2xl relative overflow-hidden group">
              <!-- Embedded Laser Scanning Effect -->
              <div class="laser-scanner"></div>
              
              <!-- CCTV Center Premium Photo with AVIF/WebP sources -->
              <div class="relative h-[420px] rounded-2xl overflow-hidden">
                <picture>
                  <source srcset="https://images.unsplash.com/photo-1563986768609-322da13575f3?auto=format&fit=crop&w=800&fm=avif&q=70" type="image/avif" />
                  <source srcset="https://images.unsplash.com/photo-1563986768609-322da13575f3?auto=format&fit=crop&w=800&fm=webp&q=80" type="image/webp" />
                  <img
                    src="https://images.unsplash.com/photo-1563986768609-322da13575f3?auto=format&fit=crop&w=800&q=80"
                    alt="Monitoreo Centralizado COPIV S.A."
                    width={800}
                    height={420}
                    loading="eager"
                    fetchpriority="high"
                    class="w-full h-full object-cover grayscale contrast-125 transition-all duration-700 group-hover:scale-105 group-hover:grayscale-0"
                  />
                </picture>
                <div class="absolute inset-0 bg-gradient-to-t from-black/80 via-black/30 to-transparent"></div>
                
                <!-- Floating Card Over Photo -->
                <div class="absolute bottom-4 left-4 right-4 bg-white/95 backdrop-blur-md p-4 rounded-xl border border-gray-200 shadow-lg">
                  <div class="flex items-center gap-3">
                    <div class="w-8 h-8 rounded-full bg-copiv-green/10 flex items-center justify-center text-copiv-green animate-pulse">
                      <i class="fa-solid fa-satellite-dish"></i>
                    </div>
                    <div class="text-left">
                      <h4 class="font-montserrat font-bold text-xs text-gray-900 m-0">Centro de Operaciones Activo</h4>
                      <p class="text-[10px] text-gray-600 m-0">Monitoreo con IA & Reacción inmediata</p>
                    </div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Highlighted Services Section -->
  <div class="py-20 bg-copiv-black border-b border-copiv-green/10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center max-w-3xl mx-auto mb-16 space-y-4">
        <span class="text-copiv-red font-bold text-sm uppercase tracking-widest block">Nuestra Oferta Especializada</span>
        <h2 class="text-3xl md:text-4xl font-montserrat font-extrabold text-gray-900 m-0">Soluciones robustas adaptadas a su sector</h2>
        <div class="w-24 h-1 bg-copiv-gold mx-auto rounded-full"></div>
        <p class="text-gray-600">Proporcionamos protección activa mediante la perfecta sinergia entre agentes de seguridad profesionales y alta tecnología.</p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
        <!-- Card 1 (Physical Guards) -->
        <div class="service-card bg-white border border-gray-200 rounded-2xl overflow-hidden flex flex-col justify-between shadow-sm">
          <div class="relative h-48 overflow-hidden">
            <Image 
              src="https://images.unsplash.com/photo-1507207611509-ec012433ff52?auto=format&fit=crop&w=800&q=80" 
              alt="Agente de Seguridad COPIV" 
              width={400}
              height={250}
              loading="lazy"
              class="w-full h-full object-cover transition-all duration-500 hover:scale-110" 
            />
            <div class="absolute inset-0 bg-gradient-to-t from-copiv-darkGray to-transparent"></div>
            <span class="absolute top-4 right-4 bg-copiv-green/80 backdrop-blur-md text-copiv-gold text-[10px] uppercase font-bold px-3 py-1 rounded-full border border-copiv-gold/30">Física</span>
          </div>
          <div class="p-6 flex-grow flex flex-col justify-between">
            <div class="text-left">
              <h3 class="font-montserrat font-bold text-xl text-gray-900 mb-2">Agentes de Seguridad Física</h3>
              <p class="text-gray-600 text-xs leading-relaxed mb-6 font-sans">Personal altamente certificado, evaluado periódicamente en tácticas de defensa, primeros auxilios y control de accesos para resguardar instalaciones sensibles.</p>
            </div>
            <a href={resolvePath('servicios')} class="text-copiv-green hover:text-copiv-greenLight font-bold text-xs flex items-center gap-2 transition w-fit decoration-none cursor-pointer">
              Ver perfiles disponibles <i class="fa-solid fa-chevron-right text-[10px]"></i>
            </a>
          </div>
        </div>

        <!-- Card 2 (CCTV with AI) -->
        <div class="service-card bg-white border border-gray-200 rounded-2xl overflow-hidden flex flex-col justify-between shadow-sm">
          <div class="relative h-48 overflow-hidden">
            <Image 
              src="https://images.unsplash.com/photo-1557597774-9d273605dfa9?auto=format&fit=crop&w=800&q=80" 
              alt="CCTV con Inteligencia Artificial" 
              width={400}
              height={250}
              loading="lazy"
              class="w-full h-full object-cover transition-all duration-500 hover:scale-110" 
            />
            <div class="absolute inset-0 bg-gradient-to-t from-white to-transparent"></div>
            <span class="absolute top-4 right-4 bg-copiv-red/80 backdrop-blur-md text-white text-[10px] uppercase font-bold px-3 py-1 rounded-full border border-copiv-red/30">Tecnología</span>
          </div>
          <div class="p-6 flex-grow flex flex-col justify-between">
            <div class="text-left">
              <h3 class="font-montserrat font-bold text-xl text-gray-900 mb-2">Catálogo Tecnológico (CCTV y Alarmas)</h3>
              <p class="text-gray-600 text-xs leading-relaxed mb-6 font-sans">Instalación y monitoreo preventivo de circuitos cerrados de videovigilancia integrando analíticas predictivas que alertan automáticamente sobre amenazas latentes.</p>
            </div>
            <a href={resolvePath('productos')} class="text-copiv-green hover:text-copiv-greenLight font-bold text-xs flex items-center gap-2 transition w-fit decoration-none cursor-pointer">
              Ver catálogo de soluciones <i class="fa-solid fa-chevron-right text-[10px]"></i>
            </a>
          </div>
        </div>

        <!-- Card 3 (Smart Gate) -->
        <div class="service-card bg-white border border-gray-200 rounded-2xl overflow-hidden flex flex-col justify-between shadow-sm">
          <div class="relative h-48 overflow-hidden">
            <Image 
              src="https://images.unsplash.com/photo-1497366216548-37526070297c?auto=format&fit=crop&w=800&q=80" 
              alt="Garitas Inteligentes SMART" 
              width={400}
              height={250}
              loading="lazy"
              class="w-full h-full object-cover transition-all duration-500 hover:scale-110" 
            />
            <div class="absolute inset-0 bg-gradient-to-t from-white to-transparent"></div>
            <span class="absolute top-4 right-4 bg-copiv-gold/85 backdrop-blur-md text-copiv-black text-[10px] uppercase font-bold px-3 py-1 rounded-full border border-copiv-black/30">Smart</span>
          </div>
          <div class="p-6 flex-grow flex flex-col justify-between">
            <div class="text-left">
              <h3 class="font-montserrat font-bold text-xl text-gray-900 mb-2">Control de Acceso y Garitas</h3>
              <p class="text-gray-600 text-xs leading-relaxed mb-6 font-sans">Automatización inteligente del acceso a condominios y parques industriales, permitiendo control por bitácora y validación remota ágil de visitas mediante biometría.</p>
            </div>
            <a href={resolvePath('productos')} class="text-copiv-green hover:text-copiv-greenLight font-bold text-xs flex items-center gap-2 transition w-fit decoration-none cursor-pointer">
              Explorar controles de acceso <i class="fa-solid fa-chevron-right text-[10px]"></i>
            </a>
          </div>
        </div>
      </div>
    </div>
  </div>

  <!-- Trust Badges & Compliance Section -->
  <div class="bg-white border-t border-b border-gray-200 py-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <span class="text-xs text-copiv-green font-bold uppercase tracking-widest block mb-6">Garantía de Legalidad y Cumplimiento de Operaciones</span>
      <div class="grid grid-cols-2 md:grid-cols-4 gap-6 items-center justify-items-center opacity-85">
        <div class="flex flex-col items-center space-y-1">
          <i class="fa-solid fa-gavel text-3xl text-copiv-green"></i>
          <span class="text-xs font-semibold text-gray-800 mt-2">DIGESSP Sello de Gobernación</span>
          <span class="text-[9px] text-gray-500">Bajo Normativa de Guatemala</span>
        </div>
        <div class="flex flex-col items-center space-y-1">
          <i class="fa-solid fa-shield-halved text-3xl text-copiv-green"></i>
          <span class="text-xs font-semibold text-gray-800 mt-2">Certificación ISO 9001</span>
          <span class="text-[9px] text-gray-500">Procesos de Calidad Internacional</span>
        </div>
        <div class="flex flex-col items-center space-y-1">
          <i class="fa-solid fa-user-secret text-3xl text-copiv-green"></i>
          <span class="text-xs font-semibold text-gray-800 mt-2">Control Antinarcóticos BASC</span>
          <span class="text-[9px] text-gray-500">Cadena de Suministro Segura</span>
        </div>
        <div class="flex flex-col items-center space-y-1">
          <i class="fa-solid fa-user-check text-3xl text-copiv-green"></i>
          <span class="text-xs font-semibold text-gray-800 mt-2">Garantía de Confianza de Agentes</span>
          <span class="text-[9px] text-gray-500">Pruebas de Polígrafo y Toxicológicas</span>
        </div>
      </div>
    </div>
  </div>

  <!-- Intermediate CTA Section -->
  <div class="relative py-20 bg-gradient-to-r from-copiv-green to-copiv-greenDark border-b border-copiv-green/30 overflow-hidden">
    <div class="absolute inset-0 opacity-20">
      <Image 
        src="https://images.unsplash.com/photo-1519501025264-65ba15a82390?auto=format&fit=crop&w=1200&q=80" 
        alt="CTA background"
        width={1200}
        height={600}
        loading="lazy"
        class="w-full h-full object-cover animate-[pulse_8s_infinite]" 
      />
    </div>
    <div class="relative z-10 max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 text-center space-y-6">
      <h3 class="text-2xl sm:text-3xl font-montserrat font-bold text-white m-0">¿Desea evaluar el nivel de vulnerabilidad de su organización?</h3>
      <p class="text-gray-300 max-w-2xl mx-auto font-light text-sm sm:text-base font-sans leading-relaxed">Nuestro algoritmo de autodiagnóstico calcula dinámicamente las debilidades de sus instalaciones físicas y electrónicas de forma gratuita en 2 minutos.</p>
      <div class="flex justify-center gap-4">
        <a href={resolvePath('diagnostico')} class="bg-copiv-gold hover:bg-copiv-goldDark text-copiv-black font-extrabold px-8 py-3.5 rounded-xl transition-all shadow-md hover:scale-105 decoration-none cursor-pointer">
          Iniciar Diagnóstico de Riesgos <i class="fa-solid fa-arrow-trend-up ml-2"></i>
        </a>
      </div>
    </div>
  </div>

  <!-- Empresa & Contacto Hub -->
  <div class="bg-white py-16 border-b border-gray-200">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-8">
        
        <div class="bg-gray-50 border border-gray-200 rounded-2xl p-8 flex flex-col justify-between hover:shadow-lg transition-shadow">
          <div>
            <i class="fa-solid fa-building-shield text-4xl text-copiv-green mb-4"></i>
            <h3 class="text-2xl font-montserrat font-bold text-gray-900 mb-3">Conozca nuestra trayectoria</h3>
            <p class="text-gray-600 font-sans mb-6">Respaldamos cada uno de nuestros servicios con años de experiencia, rigurosos procesos de selección y un firme compromiso con la seguridad de Guatemala.</p>
          </div>
          <a href={resolvePath('empresa')} class="text-copiv-green font-bold flex items-center gap-2 hover:text-copiv-gold transition-colors decoration-none w-fit">
            Leer sobre La Empresa <i class="fa-solid fa-arrow-right"></i>
          </a>
        </div>

        <div class="bg-gray-50 border border-gray-200 rounded-2xl p-8 flex flex-col justify-between hover:shadow-lg transition-shadow">
          <div>
            <i class="fa-solid fa-headset text-4xl text-copiv-red mb-4"></i>
            <h3 class="text-2xl font-montserrat font-bold text-gray-900 mb-3">Atención Inmediata 24/7</h3>
            <p class="text-gray-600 font-sans mb-6">Nuestros asesores técnicos y tácticos están disponibles para atender emergencias, cotizaciones o resolver dudas operativas al instante.</p>
          </div>
          <a href={resolvePath('contacto')} class="text-copiv-red font-bold flex items-center gap-2 hover:text-copiv-gold transition-colors decoration-none w-fit">
            Contáctenos ahora <i class="fa-solid fa-arrow-right"></i>
          </a>
        </div>

      </div>
    </div>
  </div>

</BaseLayout>

<script>
  import { gsap } from 'gsap';

  function animateHero() {
    gsap.from('.gsap-hero-item', {
      opacity: 0,
      y: 40,
      duration: 0.8,
      stagger: 0.15,
      ease: 'power3.out'
    });
  }

  // Run on initial page load
  animateHero();
  // Run after Astro view transitions
  document.addEventListener('astro:after-swap', animateHero);
</script>
