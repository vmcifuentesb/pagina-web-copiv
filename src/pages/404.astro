---
import BaseLayout from '../layouts/BaseLayout.astro';
import { resolvePath } from '../utils/constants';
---

<BaseLayout title="Página no encontrada - COPIV TIKAL" description="La página que buscas no existe.">
  <div class="min-h-[60vh] flex flex-col items-center justify-center text-center px-4 space-y-6">
    <span class="text-8xl font-black font-montserrat text-copiv-red">404</span>
    <h1 class="text-2xl font-montserrat font-bold text-gray-900 m-0">Página no encontrada</h1>
    <p class="text-gray-600 max-w-md font-sans">La ruta de seguridad solicitada no está en nuestro perímetro.</p>
    <a href={resolvePath('')} class="bg-gradient-to-r from-copiv-red to-copiv-redDark text-white font-bold px-8 py-3.5 rounded-xl shadow-lg hover:scale-105 transition-all decoration-none inline-block cursor-pointer">
      Volver al inicio
    </a>
  </div>
</BaseLayout>
