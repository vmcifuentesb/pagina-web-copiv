---
import { resolvePath } from '../../utils/constants';
---

<footer class="bg-copiv-greenDark border-t border-copiv-green/30 py-12 text-gray-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-8">
      <!-- Branding column -->
      <div class="space-y-4">
        <div class="flex items-center gap-3">
          <div class="border-l-4 border-copiv-gold pl-3">
            <span class="font-montserrat font-black text-xl text-white block leading-none">COPIV</span>
            <span class="font-montserrat font-bold text-[9px] text-copiv-gold tracking-widest block uppercase mt-0.5">TIKAL S.A.</span>
          </div>
        </div>
        <p class="text-xs text-gray-400 leading-relaxed font-light font-sans">
          Soluciones tácticas y tecnológicas en seguridad privada para resguardar la vida y patrimonio nacional.
        </p>
      </div>

      <!-- Navigation columns -->
      <div>
        <h5 class="font-montserrat font-bold text-sm text-white mb-4">Nuestra Empresa</h5>
        <ul class="text-xs text-gray-400 space-y-2 font-sans list-none p-0">
          <li><a href={resolvePath('')} class="hover:text-copiv-gold transition decoration-none">Inicio</a></li>
          <li><a href={resolvePath('empresa')} class="hover:text-copiv-gold transition decoration-none">Quiénes Somos</a></li>
          <li><a href={resolvePath('servicios')} class="hover:text-copiv-gold transition decoration-none">Servicios de Guardias</a></li>
          <li><a href={resolvePath('productos')} class="hover:text-copiv-gold transition decoration-none">Soluciones Tecnológicas</a></li>
          <li><a href={resolvePath('contacto')} class="hover:text-copiv-gold transition decoration-none">Contacto</a></li>
        </ul>
      </div>

      <!-- Services Column -->
      <div>
        <h5 class="font-montserrat font-bold text-sm text-white mb-4 font-sans">Soluciones de Elite</h5>
        <ul class="text-xs text-gray-400 space-y-2 font-sans list-none p-0">
          <li>Plataforma de Garitas SMART</li>
          <li>Cámaras IP</li>
          <li>Monitoreo con Inteligencia Artificial</li>
          <li>Custodia de Valores e Instalaciones</li>
        </ul>
      </div>

      <!-- Legal/Credits -->
      <div class="space-y-4">
        <h5 class="font-montserrat font-bold text-sm text-white mb-4">Contáctenos</h5>
        <p class="text-xs text-gray-400 leading-relaxed font-light font-sans">
          15 avenida 1-73 Ciudad San Cristóbal Z.8 Mixco.<br />
          Tels: +502 3099 0692 | (502) 4854-2084
        </p>
        <div class="flex gap-3 text-lg">
          <a href="https://facebook.com" target="_blank" class="text-gray-400 hover:text-white transition hover:scale-110"><i class="fa-brands fa-facebook"></i></a>
          <a href="https://instagram.com" target="_blank" class="text-gray-400 hover:text-white transition hover:scale-110"><i class="fa-brands fa-instagram"></i></a>
          <a href="https://linkedin.com" target="_blank" class="text-gray-400 hover:text-white transition hover:scale-110"><i class="fa-brands fa-linkedin"></i></a>
        </div>
      </div>
    </div>

    <!-- Bottom Disclaimer -->
    <div class="border-t border-copiv-green/20 mt-12 pt-6 text-center flex flex-col sm:flex-row justify-between items-center text-[10px] text-gray-500 gap-4">
      <p>&copy; 2026 COPIV TIKAL S.A. Todos los derechos reservados.</p>
      <div class="flex gap-4 font-sans">
        <a href={resolvePath('privacidad')} class="hover:text-copiv-gold transition">Políticas de Privacidad</a>
        <a href={resolvePath('terminos')} class="hover:text-copiv-gold transition">Términos del Servicio</a>
      </div>
    </div>
  </div>
</footer>
